PORT=5000
MONGO_URI=mongodb://localhost:27017/sangam_motors_crm

# Generate a long random string for this in production, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# Comma-separated list of frontend URLs allowed to call this API in production
# e.g. CORS_ORIGIN=https://crm.sangammotors.in,https://sangam-crm.vercel.app
CORS_ORIGIN=
